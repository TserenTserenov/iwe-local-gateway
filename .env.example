# local-gateway — конфигурация
# Скопировать в .env и заполнить значения. НЕ коммитить .env

# ─── Идентификатор агента ────────────────────────────────────────────────
# Уникальный ID текущего Claude Code агента (например: claude-main, kimi-1)
IWE_AGENT_ID=claude-main

# ─── Пути (опционально, есть умолчания) ─────────────────────────────────
# IWE_GATEWAY_SOCKET=~/.iwe-runtime/gateway.sock
# IWE_METRICS_PATH=~/.iwe-runtime/metrics.json
